pipeline {
    agent any

    triggers {
        pollSCM('H/2 * * * *')
    }

    options {
        timestamps()
        skipDefaultCheckout(false)
        buildDiscarder(logRotator(numToKeepStr: '20'))
    }

    parameters {
        booleanParam(name: 'RUN_SOURCE_SCAN', defaultValue: true, description: 'Scan source code with OPSWAT MDSSC before building.')
        booleanParam(name: 'RUN_ARTIFACT_SCAN', defaultValue: true, description: 'Scan build artifacts with OPSWAT MDSSC.')
        booleanParam(name: 'RUN_DEPLOY', defaultValue: false, description: 'Deploy to production VPS after scans pass.')
        string(name: 'MDSSC_SERVER', defaultValue: 'http://35.156.106.42', description: 'MDSSC server URL.')
        string(name: 'MDSSC_WORKFLOW_ID', defaultValue: '', description: 'Optional MDSSC workflow ID.')
        choice(name: 'MDSSC_VULNERABILITY_THRESHOLD', choices: ['critical', 'high', 'medium', 'low'], description: 'Minimum vulnerability severity that fails the build.')
        booleanParam(name: 'MDSSC_FAIL_ON_VULNERABILITIES', defaultValue: false, description: 'Fail pipeline when MDSSC finds vulnerabilities at or above the threshold.')
        string(name: 'PROD_HOST', defaultValue: '', description: 'Production SSH target, for example deploy@your-vps-ip.')
        string(name: 'PROD_PATH', defaultValue: '/opt/roventura', description: 'Application path on production VPS.')
        string(name: 'PROD_SSH_CREDENTIALS_ID', defaultValue: '', description: 'Jenkins SSH private key credentials ID for production deploy.')
    }

    environment {
        BACKEND_DIR = 'backend'
        FRONTEND_DIR = 'my-app'
        ARTIFACT_DIR = 'artifacts'
        COMPOSE_PROJECT_NAME = 'roventura'
        BACKEND_IMAGE = 'roventura-backend'
        FRONTEND_IMAGE = 'roventura-frontend'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                sh 'git rev-parse --abbrev-ref HEAD || true'
                sh 'git rev-parse --short HEAD || true'
            }
        }

        stage('Prepare') {
            steps {
                sh 'docker --version'
                sh 'docker compose version'
                sh 'node --version'
                sh 'npm --version'
                sh 'rm -rf "$ARTIFACT_DIR" && mkdir -p "$ARTIFACT_DIR"'
                sh '''
                    tar -czf "$ARTIFACT_DIR/source-code.tar.gz" \
                        --exclude=.git \
                        --exclude=artifacts \
                        --exclude=node_modules \
                        --exclude='*/node_modules' \
                        --exclude='*/dist' \
                        --exclude='*/build' \
                        --exclude='*/coverage' \
                        --exclude='*.log' \
                        .
                '''
            }
        }

        stage('Scan source code with MDSSC') {
            when {
                expression { return params.RUN_SOURCE_SCAN }
            }
            steps {
                script {
                    runMdsscFileScan("${ARTIFACT_DIR}/source-code.tar.gz", 'source-code')
                }
            }
        }

        stage('Install dependencies') {
            parallel {
                stage('Backend dependencies') {
                    steps {
                        dir("${BACKEND_DIR}") {
                            sh 'npm ci'
                        }
                    }
                }

                stage('Frontend dependencies') {
                    steps {
                        dir("${FRONTEND_DIR}") {
                            sh 'npm ci'
                        }
                    }
                }
            }
        }

        stage('Build artifacts') {
            steps {
                dir("${FRONTEND_DIR}") {
                    sh 'npm run build'
                }

                sh '''
                    tar -czf "$ARTIFACT_DIR/frontend-dist.tar.gz" -C "$FRONTEND_DIR/dist" .
                    tar -czf "$ARTIFACT_DIR/backend-source.tar.gz" \
                        --exclude=node_modules \
                        --exclude=uploads \
                        -C "$BACKEND_DIR" .
                    docker compose build backend frontend
                    docker image inspect "$BACKEND_IMAGE" "$FRONTEND_IMAGE" >/dev/null
                    docker save -o "$ARTIFACT_DIR/docker-images.tar" "$BACKEND_IMAGE" "$FRONTEND_IMAGE"
                '''
            }
        }

        stage('Scan artifacts with MDSSC') {
            when {
                expression { return params.RUN_ARTIFACT_SCAN }
            }
            steps {
                script {
                    runMdsscArtifactScan()
                }
            }
        }

        stage('Archive artifacts') {
            steps {
                archiveArtifacts artifacts: "${ARTIFACT_DIR}/**", fingerprint: true
            }
        }

        stage('Deploy to production') {
            when {
                allOf {
                    expression { return params.RUN_DEPLOY }
                    expression { return params.PROD_HOST?.trim() }
                    expression { return params.PROD_SSH_CREDENTIALS_ID?.trim() }
                }
            }
            steps {
                sshagent(credentials: [params.PROD_SSH_CREDENTIALS_ID]) {
                    sh '''
                        tar \
                            --exclude .git \
                            --exclude node_modules \
                            --exclude artifacts \
                            -czf - . | ssh -o StrictHostKeyChecking=no "$PROD_HOST" "mkdir -p '$PROD_PATH' && tar -xzf - -C '$PROD_PATH' && cd '$PROD_PATH' && docker compose up -d --build"
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'CI/CD pipeline completed successfully.'
        }
        failure {
            echo 'Pipeline failed. Check Jenkins console logs.'
        }
        always {
            deleteDir()
        }
    }
}

void runMdsscScan(String scanPath, String label) {
    String mdsscServer = params.MDSSC_SERVER?.trim() ?: 'http://35.156.106.42'

    if (!mdsscServer) {
        error("MDSSC_SERVER is required when ${label} scanning is enabled.")
    }

    String workflowEnv = params.MDSSC_WORKFLOW_ID?.trim()
        ? "-e WORKFLOW_ID='${params.MDSSC_WORKFLOW_ID.trim()}'"
        : ''

    withCredentials([string(credentialsId: 'mdssc-api-key', variable: 'MDSSC_API_KEY')]) {
        sh """
            docker run --rm \
                --volumes-from "\$HOSTNAME" \
                -e MDSSC_SERVER='${mdsscServer}' \
                -e MDSSC_API_KEY="\$MDSSC_API_KEY" \
                -e SCAN_TIMEOUT='900' \
                -e POLL_INTERVAL='10' \
                -e FAIL_ON_VULNERABILITIES='${params.MDSSC_FAIL_ON_VULNERABILITIES}' \
                -e VULNERABILITY_THRESHOLD='${params.MDSSC_VULNERABILITY_THRESHOLD}' \
                ${workflowEnv} \
                opswat/mdssc-scanner:latest "\$PWD/${scanPath}"
        """
    }
}

void runMdsscFileScan(String filePath, String label) {
    String mdsscServer = params.MDSSC_SERVER?.trim() ?: 'http://35.156.106.42'

    String workflowEnv = params.MDSSC_WORKFLOW_ID?.trim()
        ? "-e WORKFLOW_ID='${params.MDSSC_WORKFLOW_ID.trim()}'"
        : ''

    withCredentials([string(credentialsId: 'mdssc-api-key', variable: 'MDSSC_API_KEY')]) {
        sh """
            set -eu
            if [ ! -f "${filePath}" ]; then
                echo "MDSSC ${label} input file not found: ${filePath}"
                exit 1
            fi

            echo "Scanning ${label} with MDSSC: ${filePath}"

            docker run --rm \
                --volumes-from "\$HOSTNAME" \
                -e MDSSC_SERVER='${mdsscServer}' \
                -e MDSSC_API_KEY="\$MDSSC_API_KEY" \
                -e SCAN_TIMEOUT='900' \
                -e POLL_INTERVAL='10' \
                -e FAIL_ON_VULNERABILITIES='${params.MDSSC_FAIL_ON_VULNERABILITIES}' \
                -e VULNERABILITY_THRESHOLD='${params.MDSSC_VULNERABILITY_THRESHOLD}' \
                ${workflowEnv} \
                opswat/mdssc-scanner:latest "\$PWD/${filePath}"
        """
    }
}

void runMdsscArtifactScan() {
    String mdsscServer = params.MDSSC_SERVER?.trim() ?: 'http://35.156.106.42'

    String workflowEnv = params.MDSSC_WORKFLOW_ID?.trim()
        ? "-e WORKFLOW_ID='${params.MDSSC_WORKFLOW_ID.trim()}'"
        : ''

    withCredentials([string(credentialsId: 'mdssc-api-key', variable: 'MDSSC_API_KEY')]) {
        sh """
            set -eu

            artifact_count=\$(find "\$ARTIFACT_DIR" -maxdepth 1 -type f | wc -l)
            if [ "\$artifact_count" -eq 0 ]; then
                echo "No artifact files found in \$ARTIFACT_DIR"
                exit 1
            fi

            find "\$ARTIFACT_DIR" -maxdepth 1 -type f ! -name 'source-code.tar.gz' -print | while IFS= read -r artifact; do
                artifact_name=\$(basename "\$artifact")
                echo "Scanning artifact with MDSSC: \$artifact_name"

                docker run --rm \
                    --volumes-from "\$HOSTNAME" \
                    -e MDSSC_SERVER='${mdsscServer}' \
                    -e MDSSC_API_KEY="\$MDSSC_API_KEY" \
                    -e SCAN_TIMEOUT='900' \
                    -e POLL_INTERVAL='10' \
                    -e FAIL_ON_VULNERABILITIES='${params.MDSSC_FAIL_ON_VULNERABILITIES}' \
                    -e VULNERABILITY_THRESHOLD='${params.MDSSC_VULNERABILITY_THRESHOLD}' \
                    ${workflowEnv} \
                    opswat/mdssc-scanner:latest "\$PWD/\$artifact"
            done
        """
    }
}
